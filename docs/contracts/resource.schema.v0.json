{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nai.local/schemas/resource.schema.v0.json",
  "title": "NAI Resource Contract v0",
  "description": "Schéma canonical MVP pour les métadonnées de ressource NAI.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "title",
    "category",
    "theme",
    "description",
    "content_ref",
    "related"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Convention d'identifiant: domain.topic.item (segments supplémentaires autorisés).",
      "pattern": "^[a-z0-9]+(?:\\.[a-z0-9][a-z0-9_-]*){2,}$",
      "examples": [
        "action.data.csv.clean",
        "docs.system.logs.rotation_policy"
      ]
    },
    "type": {
      "type": "string",
      "enum": [
        "action",
        "code",
        "doc",
        "config",
        "template",
        "reference"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120
    },
    "category": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "theme": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "description": {
      "type": "string",
      "minLength": 5,
      "maxLength": 500
    },
    "content_ref": {
      "type": "string",
      "description": "Chemin relatif depuis la racine du repo. Interdit: absolu, ../, URL.",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?![a-z]+://)[A-Za-z0-9._/-]+$",
      "minLength": 3,
      "maxLength": 240,
      "examples": [
        "resources/scripts/clean_csv.sh",
        "resources/docs/log_rotation_policy.md"
      ]
    },
    "variables": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "kind"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean",
            "default": true
          },
          "default": {},
          "description": {
            "type": "string",
            "maxLength": 240
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "description": "Tags normalisés en lowercase kebab-case.",
      "default": [],
      "uniqueItems": true,
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 32,
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "related": {
      "type": "array",
      "description": "Relations sortantes: liste d'IDs de ressources ciblées.",
      "default": [],
      "uniqueItems": true,
      "maxItems": 50,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:\\.[a-z0-9][a-z0-9_-]*){2,}$"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "author": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "version": {
          "type": "string",
          "pattern": "^v?\\d+\\.\\d+\\.\\d+$"
        },
        "updated_at": {
          "type": "string",
          "format": "date"
        }
      }
    }
  },
  "examples": [
    {
      "id": "action.data.csv.clean",
      "type": "action",
      "title": "Clean CSV",
      "category": "data",
      "theme": "csv",
      "description": "Nettoie un CSV avec règles de base.",
      "content_ref": "resources/scripts/clean_csv.sh",
      "tags": [
        "csv",
        "data-cleaning"
      ],
      "related": [
        "code.csv.extract_fields",
        "docs.data.csv.extract"
      ]
    }
  ]
}
